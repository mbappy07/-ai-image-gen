# ====== 数据库 ======
DATABASE_URL="mysql://root:password@localhost:3306/ai_image_gen"

# ====== 阿里云 DashScope (AI 生图) ======
ALIYUN_ACCESS_KEY="your_aliyun_access_key_id"
ALIYUN_SECRET_KEY="your_aliyun_access_key_secret"
DASHSCOPE_API_KEY="your_dashscope_api_key"
DASHSCOPE_MODEL="wan2.1-t2i-turbo"
DASHSCOPE_WORKSPACE="ws-xxxxxxxx"

# ====== 阿里云 OSS (图片存储) ======
OSS_ACCESS_KEY="your_oss_access_key_id"
OSS_SECRET_KEY="your_oss_access_key_secret"
OSS_BUCKET="ai-image-gen"
OSS_REGION="oss-cn-hangzhou"
OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"

# ====== 应用 ======
NEXT_PUBLIC_APP_URL="http://localhost:3000"
